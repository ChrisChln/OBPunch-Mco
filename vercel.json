{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/todo-recurring-sync",
      "schedule": "5 9 * * *"
    },
    {
      "path": "/api/consumable-alert-sync",
      "schedule": "15 16 * * *"
    }
  ]
}
